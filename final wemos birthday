      display.setCursor(10,20);
      display.println("Semoga sehat selalu");
      break;

    case 2:
      display.setCursor(10,20);
      display.println("Panjang umur");
      break;

    case 3:
      display.setCursor(10,20);
      display.println("Doa yang terbaik");
      break;

    case 4:
      display.setCursor(10,20);
      display.println("Semoga kamu suka yh");
      break;
  }

  display.display();
}

