void drawPhoto(int index)
{
  display.clearDisplay();

  display.drawBitmap(
    0,
    0,
    photos[index],
    128,
    64,
    WHITE
  );

  display.display();
}

void drawMochi(int frame)
{
  display.clearDisplay();

  display.drawBitmap(
    0,
    0,
    mochiFrames[frame],
    128,
    64,
    WHITE
  );

  display.display();
}
// =========================================

void nextPage()
{
  if(currentState == ANIMATION)
  {
    currentState = GREETING;
    greetingPage = 0;

    if(!musicStarted)
      startSong();

    drawGreeting(greetingPage);
  }

  else if(currentState == GREETING)
  {
    greetingPage++;

    if(greetingPage < 5)
    {
      drawGreeting(greetingPage);
    }
    else
    {
      currentState = PHOTOS;
      photoPage = 0;

      drawPhoto(photoPage);
    }
  }

  else if(currentState == PHOTOS)
  {
    photoPage++;

    if(photoPage < 55)
    {
      drawPhoto(photoPage);
    }
    else
    {
      currentState = HAPPY_EYES;
eyeFrame = 0;

drawMochi(eyeFrame);
    }
  }
  else if(currentState == HAPPY_EYES)
{
      currentState = ANIMATION;
      animationFrame = 0;

      drawCake(animationFrame);
    }
  }


// =========================================

void setup()
{
  pinMode(TOUCH_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin(D2, D1);

  display.begin(
    SSD1306_SWITCHCAPVCC,
    0x3C
  );

  display.clearDisplay();
  display.display();

  drawCake(0);
}

// =========================================

void loop()
{
  updateSong();

  // animasi kue
  if(currentState == ANIMATION)
  {
    if(millis() - lastFrameTime > 150)
    {
      animationFrame++;

      if(animationFrame >= 43)
        animationFrame = 0;

      drawCake(animationFrame);

      lastFrameTime = millis();
    }
  }

  if(currentState == HAPPY_EYES)
{
    if(millis() - lastFrameTime > 70)
    {
      eyeFrame++;

     if(eyeFrame >= 33)
        eyeFrame = 0;

      drawMochi(eyeFrame);

      lastFrameTime = millis();
    }
}

  bool touch = digitalRead(TOUCH_PIN);

  if(touch && !lastTouch)
  {
    nextPage();

    delay(200);
  }

  lastTouch = touch;
}
