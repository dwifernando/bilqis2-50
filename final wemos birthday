void updateSong()
{
  if(!musicStarted || songFinished)
    return;

  unsigned long now = millis();

  if(!notePlaying)
  {
    tone(BUZZER_PIN, melody[currentNote]);

    noteStartTime = now;
    notePlaying = true;
  }
  else
  {
    if(now - noteStartTime >= noteDuration[currentNote])
    {
      noTone(BUZZER_PIN);

      currentNote++;

      notePlaying = false;

      if(currentNote >= TOTAL_NOTES)
      {
        songFinished = true;
        noTone(BUZZER_PIN);
      }
    }
  }
}

